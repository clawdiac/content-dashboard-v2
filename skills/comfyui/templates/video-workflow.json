      "title": "KSampler (Video)"
    }
  },
  "6": {
    "inputs": {
      "samples": [
        "5",
        0
      ],
      "vae": [
        "1",
        2
      ]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "7": {
    "inputs": {
      "codec": "h264",
      "quality": 95,
      "fps": 24,
      "minimize_blocking": false,

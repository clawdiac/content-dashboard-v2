    }
  },
  "3": {
    "inputs": {
      "text": "blurry, low quality, static, nsfw",
      "clip": [
        "1",
        1
      ]
    },
    "class_type": "CLIPTextEncode (Negative)",
    "_meta": {
      "title": "CLIP Text Encode (Negative)"
    }
  },
  "4": {
    "inputs": {
      "width": 1024,
      "height": 576,
      "length": 24,
      "batch_size": 1
    },
    "class_type": "EmptyLatentVideo",
    "_meta": {
      "title": "Empty Latent Video"
    }
  },
  "5": {
    "inputs": {

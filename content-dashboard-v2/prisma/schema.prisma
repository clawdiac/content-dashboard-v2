generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          String    @default("va")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  contentItems  ContentItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Batch {
  id               String        @id @default(cuid())
  name             String?
  type             String        // "image" | "video"
  status           String        @default("pending") // pending|processing|completed|failed
  totalItems       Int           @default(0)
  completed        Int           @default(0)
  failed           Int           @default(0)
  campaignName     String?
  templatePresetId String?
  rerunnable       Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  items            ContentItem[]

  @@index([campaignName])
}

model ContentItem {
  id             String           @id @default(cuid())
  title          String
  prompt         String
  negativePrompt String?
  generator      String           @default("nano_banana_pro")
  generationParams Json?
  status         String           @default("generating")
  imageUrl       String?
  editedUrl      String?
  assignedToId   String?
  assignedTo     User?            @relation(fields: [assignedToId], references: [id])
  batchId        String?
  batch          Batch?           @relation(fields: [batchId], references: [id])
  type           String           @default("image") // "image" | "video"
  presetId       String?
  preset         CharacterPreset? @relation(fields: [presetId], references: [id])
  characterId    String?
  character      Character?       @relation(fields: [characterId], references: [id])
  parentImageId  String?          // video items link back to approved image
  videoPresetId  String?
  videoPreset    VideoPreset?     @relation(fields: [videoPresetId], references: [id])
  videoUrl       String?          // URL to generated video file
  position       Int?             // order within batch
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Character {
  id              String                   @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  presets         CharacterPreset[]
  videoPresets    VideoPreset[]
  contentItems    ContentItem[]
  batchPreviews   BatchWorkflowPreview[]
  batchQueueItems BatchWorkflowQueueItem[]
  batchWorkflowsAsPreview BatchWorkflow[] @relation("BWPreviewCharacter")
}

model CharacterPreset {
  id               String        @id @default(cuid())
  name             String
  imageUrl         String
  characterId      String
  character        Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  generationParams Json?
  contentItems     ContentItem[]
}

model ReferenceImage {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  category  String?
  createdAt DateTime @default(now())
}

model VideoPreset {
  id               String        @id @default(cuid())
  name             String
  description      String?
  referenceImageUrl String?
  characterId      String
  character        Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  promptTemplate   String
  duration         Int           @default(5)
  model            String        @default("seedance")
  aspectRatio      String        @default("9:16")
  resolution       String        @default("720p")
  params           Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  contentItems     ContentItem[]
  batchWorkflows   BatchWorkflow[]
}

// ============ Batch Video Generation Workflow ============

model BatchWorkflow {
  id             String   @id @default(cuid())
  name           String?
  status         String   @default("setup") // setup|previewing|confirming|generating|completed|failed|cancelled
  workflowType   String   // "seed_lock" | "prompt_lock"
  provider       String   // "kling" | "seedance" | "veo"
  basePrompt     String   // The master prompt template
  aspectRatio    String   @default("9:16")
  duration       Int      @default(5)
  resolution     String   @default("720p")
  totalItems     Int      @default(0)
  completedItems Int      @default(0)
  failedItems    Int      @default(0)
  lockedSeed     Int?     // For seed-lock workflows: the chosen seed
  lockedPrompt   String?  // For prompt-lock workflows: the confirmed prompt
  videoPresetId  String?
  videoPreset    VideoPreset? @relation(fields: [videoPresetId], references: [id])
  previewCharacterId String?
  previewCharacter   Character? @relation("BWPreviewCharacter", fields: [previewCharacterId], references: [id])
  params         Json?    // Additional generation params
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  previews   BatchWorkflowPreview[]
  queueItems BatchWorkflowQueueItem[]
}

model BatchWorkflowPreview {
  id           String        @id @default(cuid())
  workflowId   String
  workflow     BatchWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  seed         Int?
  prompt       String
  characterId  String?
  character    Character?    @relation(fields: [characterId], references: [id])
  videoUrl     String?
  thumbnailUrl String?
  status       String        @default("pending") // pending|generating|completed|failed
  selected     Boolean       @default(false) // User selected this preview
  error        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([workflowId])
}

model BatchWorkflowQueueItem {
  id           String        @id @default(cuid())
  workflowId   String
  workflow     BatchWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  characterId  String
  character    Character     @relation(fields: [characterId], references: [id])
  prompt       String        // Character-specific prompt
  seed         Int?          // Locked seed for seed-lock workflows
  videoUrl     String?
  thumbnailUrl String?
  status       String        @default("pending") // pending|generating|completed|failed|cancelled
  error        String?
  retryCount   Int           @default(0)
  position     Int           // Order in queue
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([workflowId])
  @@index([status])
}
